# Set the token for your wearable (only one required)

# Oura Ring — https://cloud.ouraring.com/v2/docs
OURA_ACCESS_TOKEN=your_token_here

# Whoop — https://developer.whoop.com
# WHOOP_ACCESS_TOKEN=your_token_here

# Fitbit — https://dev.fitbit.com
# FITBIT_ACCESS_TOKEN=your_token_here

# Apple Health — export from iPhone Settings > Health > Export All Health Data
# APPLE_HEALTH_EXPORT=/path/to/export.xml

# Garmin — export from Garmin Connect (Settings > Export Data)
# GARMIN_EXPORT_DIR=/path/to/garmin/export

# Open Wearables — self-hosted wearable aggregation (https://openwearables.io)
# OPEN_WEARABLES_API_KEY=your_ow_api_key
# OPEN_WEARABLES_USER_ID=your_ow_user_id
# OPEN_WEARABLES_URL=http://localhost:8000

# CGM — Continuous Glucose Monitoring

# Nightscout — open-source CGM (https://nightscout.github.io)
# NIGHTSCOUT_URL=https://your-nightscout-instance.herokuapp.com
# NIGHTSCOUT_API_SECRET=your_api_secret

# Dexcom — official API (https://developer.dexcom.com)
# DEXCOM_ACCESS_TOKEN=your_dexcom_token
# DEXCOM_BASE_URL=https://sandbox-api.dexcom.com

# Optional: force a specific provider if multiple are configured
# BIOMETRIC_PROVIDER=oura

# Suna Health API — meals, gut scores, digestive states, windows, insights
# SUNA_API_URL=https://your-suna-api-url
# SUNA_API_KEY=your_suna_api_key
